.room-page {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-top: 0;
}

.room-page--left {
  min-height: 0;
  height: 100vh;
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.room-page--top {
  min-height: 0;
  height: 100vh;
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.room-toolbar {
  position: relative;
  margin-bottom: 6rpx;
}

.room-toolbar__group {
  position: absolute;
  left: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toolbar-pill {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 235, 223, 0.84));
  border: 1px solid rgba(255, 255, 255, 0.76);
  color: var(--text-secondary);
  box-shadow:
    0 12rpx 22rpx rgba(129, 98, 64, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.92),
    inset 0 -3rpx 0 rgba(201, 184, 163, 0.3);
}

.toolbar-pill--icon {
  flex: none;
}

.member-stage {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.member-strip {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.member-strip__inner {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 8rpx;
}

.stage-card {
  width: 128rpx;
  min-height: 176rpx;
  padding: 18rpx 10rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(244, 235, 223, 0.72));
  border: 1px solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 18rpx 34rpx rgba(129, 98, 64, 0.08);
  box-sizing: border-box;
}

.stage-card--self {
  border-color: rgba(185, 122, 68, 0.34);
  box-shadow:
    inset 0 0 0 2rpx rgba(185, 122, 68, 0.08),
    0 18rpx 34rpx rgba(129, 98, 64, 0.08);
}

.stage-card--selected {
  border-color: rgba(95, 150, 118, 0.36);
  background: rgba(241, 249, 244, 0.92);
}

.tea-dock {
  flex: none;
}

.stage-card--tea-fixed {
  width: 120rpx;
  min-height: 176rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(243, 233, 219, 0.9));
}

.invite-ring,
.tea-badge {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--brand);
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(185, 122, 68, 0.24);
}

.tea-badge {
  font-size: 28rpx;
  color: #fffaf2;
  background: linear-gradient(180deg, #d8a36e 0%, #c6874a 100%);
}

.stage-card__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.2;
}

.stage-card__score {
  font-size: 28rpx;
  font-weight: 700;
}

.hint-strip {
  padding: 14rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(235, 197, 104, 0.92), rgba(228, 182, 78, 0.92));
  color: #5b4421;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(204, 161, 67, 0.18);
}

.hint-swiper {
  height: 34rpx;
}

.hint-strip__item {
  height: 34rpx;
  display: flex;
  align-items: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.batch-entry {
  display: flex;
  justify-content: center;
  margin-top: -4rpx;
}

.batch-entry__button {
  width: 100%;
  padding: 4rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(242, 235, 225, 0.92));
  border: 1px solid rgba(210, 196, 177, 0.56);
  box-shadow:
    0 16rpx 24rpx rgba(129, 98, 64, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.92);
}

.batch-entry__face {
  min-height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--brand);
  background: linear-gradient(180deg, #fffdfa 0%, #f3ede5 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    inset 0 -2rpx 0 rgba(205, 190, 171, 0.28);
}

.room-layout--left {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 18rpx;
  align-items: stretch;
}

.left-rail {
  width: 148rpx;
  padding: 14rpx 12rpx;
  padding-bottom: 260rpx;
  border-radius: 32rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 0;
  background: linear-gradient(180deg, rgba(233, 199, 152, 0.28), rgba(216, 173, 123, 0.22));
  border: 1px solid rgba(255, 255, 255, 0.58);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.78),
    0 18rpx 34rpx rgba(129, 98, 64, 0.08);
  box-sizing: border-box;
}

.left-rail__main,
.left-rail__footer {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.left-rail__main {
  flex: 1;
  min-height: 0;
}

.left-rail__footer {
  position: fixed;
  left: 36rpx;
  bottom: calc(124rpx + env(safe-area-inset-bottom));
  width: 124rpx;
  z-index: 25;
}

.rail-card {
  padding: 16rpx 10rpx;
  min-height: 138rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  text-align: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(245, 236, 224, 0.76));
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow:
    0 14rpx 24rpx rgba(129, 98, 64, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
}

.rail-card--self {
  border-color: rgba(185, 122, 68, 0.28);
  box-shadow:
    inset 0 0 0 2rpx rgba(185, 122, 68, 0.08),
    0 14rpx 24rpx rgba(129, 98, 64, 0.08);
}

.rail-card__badge,
.rail-card__tea {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: var(--brand);
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(185, 122, 68, 0.22);
}

.rail-card__tea {
  color: #fffaf2;
  font-size: 26rpx;
  background: linear-gradient(180deg, #d8a36e 0%, #c6874a 100%);
}

.rail-card__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
}

.rail-card__score {
  font-size: 24rpx;
  font-weight: 700;
}

.rail-batch {
  padding: 4rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #d7a16c 0%, #c6884b 100%);
  box-shadow: 0 14rpx 24rpx rgba(129, 98, 64, 0.12);
  box-sizing: border-box;
}

.rail-batch__face {
  min-height: 84rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  color: #fffaf2;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #cf965f 0%, #c48547 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -2rpx 0 rgba(146, 91, 41, 0.22);
}

.left-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 0;
}

.hint-strip--left {
  margin-top: -2rpx;
}

.left-ledger {
  padding: 24rpx;
}

.room-content {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.room-content--top {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.room-content__main {
  min-height: 0;
}

.room-content__main--scroll {
  flex: 1;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
}

.panel-card {
  padding: 26rpx;
}

.room-help {
  margin: 18rpx 0 20rpx;
}

.ledger-list,
.keypad {
  display: grid;
  gap: 12rpx;
}

.ledger-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx;
}

.ledger-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #d4a16d 0%, #b97a44 100%);
}

.ledger-main {
  flex: 1;
  min-width: 0;
}

.ledger-title {
  margin-bottom: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
}

.ledger-main .muted,
.ledger-item > .muted {
  font-size: 22rpx;
  line-height: 1.5;
}

.ledger-item > .muted {
  flex: none;
  min-width: 58rpx;
  text-align: right;
}

.popup-sheet {
  padding: 30rpx 24rpx calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fffdf9 0%, #f7efe4 100%);
  border-radius: 36rpx 36rpx 0 0;
}

.popup-sheet__title {
  font-size: 34rpx;
  font-weight: 700;
}

.popup-sheet__desc {
  margin-top: 10rpx;
}

.amount-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  text-align: center;
}

.amount-value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 700;
}

.keypad {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 24rpx;
}

.key {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
}

.popup-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.input-shell {
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
}

.rename-input {
  height: 96rpx;
  font-size: 30rpx;
}

.settings-sheet {
  width: 620rpx;
  max-width: calc(100vw - 72rpx);
  padding: 36rpx 30rpx 34rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(246, 238, 227, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.76);
  box-shadow: 0 24rpx 44rpx rgba(84, 63, 42, 0.18);
  box-sizing: border-box;
}

.settings-sheet__head {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 26rpx;
}

.settings-sheet__title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.settings-sheet__close {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 40rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1px solid rgba(210, 196, 177, 0.22);
}

.settings-item--last {
  border-bottom: 0;
}

.settings-item__label,
.settings-layout__title {
  font-size: 32rpx;
  color: var(--text-primary);
}

.settings-card {
  padding: 8rpx 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(247, 239, 228, 0.66));
  border: 1px solid rgba(255, 255, 255, 0.76);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    0 14rpx 26rpx rgba(129, 98, 64, 0.07);
}

.settings-toggle__track {
  width: 98rpx;
  height: 56rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(210, 196, 177, 0.64);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.settings-toggle__track--active {
  background: rgba(216, 151, 145, 0.42);
  border-color: rgba(194, 104, 92, 0.3);
}

.settings-toggle__thumb {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fffdfa 0%, #f3ede5 100%);
  box-shadow:
    0 6rpx 10rpx rgba(84, 63, 42, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94);
  transition: transform 0.2s ease;
}

.settings-toggle__thumb--active {
  transform: translateX(42rpx);
  background: linear-gradient(180deg, #fef5f3 0%, #fffaf8 100%);
}

.settings-layout {
  margin-top: 18rpx;
}

.settings-layout__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0 6rpx;
}

.settings-layout__value {
  min-height: 44rpx;
}

.settings-layout__options {
  display: flex;
  gap: 16rpx;
  margin-top: 14rpx;
  padding: 0 0 18rpx;
}

.layout-option {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.74);
  color: var(--text-secondary);
  font-size: 28rpx;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.88);
}

.layout-option--active {
  color: var(--brand);
  border-color: rgba(185, 122, 68, 0.24);
  box-shadow:
    inset 0 0 0 2rpx rgba(185, 122, 68, 0.08),
    0 8rpx 18rpx rgba(185, 122, 68, 0.08);
}

.settings-actions {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}

.settings-contact {
  width: 276rpx;
  margin: 0;
  padding: 4rpx;
  border-radius: 999rpx;
  border: none;
  outline: none;
  box-sizing: border-box;
  background: linear-gradient(180deg, #d7a16c 0%, #c6884b 100%);
  box-shadow: 0 16rpx 24rpx rgba(129, 98, 64, 0.1);
}

.settings-contact::after {
  border: none;
}

.settings-contact__face {
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fffaf2;
  background: linear-gradient(180deg, #cf965f 0%, #c48547 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -2rpx 0 rgba(146, 91, 41, 0.22);
}

.batch-sheet {
  width: 664rpx;
}

.batch-sheet__title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.batch-sheet__desc {
  margin: 16rpx 8rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.7;
}

.batch-list {
  max-height: 420rpx;
}

.batch-list__inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.batch-item {
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(247, 239, 228, 0.7));
  border: 1px solid rgba(255, 255, 255, 0.78);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    0 14rpx 24rpx rgba(129, 98, 64, 0.06);
  box-sizing: border-box;
}

.batch-item__user {
  min-width: 180rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.batch-item__tea {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #fffaf2;
  background: linear-gradient(180deg, #d8a36e 0%, #c6874a 100%);
}

.batch-item__name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.batch-item__input {
  flex: 1;
  min-width: 0;
}

.batch-item__field {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.92);
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.batch-sync {
  width: 224rpx;
  margin: 26rpx auto 0;
  padding: 3rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  border: 1px solid rgba(232, 141, 134, 0.36);
  background: linear-gradient(180deg, rgba(255, 250, 249, 0.92), rgba(254, 244, 242, 0.92));
}

.batch-sync__face {
  min-height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #dc7d72;
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(180deg, #fff8f7 0%, #fff0ed 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    inset 0 -2rpx 0 rgba(238, 196, 190, 0.3);
}

.batch-actions {
  margin-top: 30rpx;
}

.tea-sheet {
  width: 664rpx;
  padding-bottom: 34rpx;
}

.tea-sheet__section {
  display: flex;
  align-items: center;
  gap: 26rpx;
  margin-bottom: 28rpx;
}

.tea-sheet__label {
  flex: none;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tea-segment {
  flex: 1;
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.92),
    0 10rpx 20rpx rgba(129, 98, 64, 0.05);
}

.tea-segment__item {
  flex: 1;
  min-height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.tea-segment__item--active {
  color: var(--brand);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(246, 238, 227, 0.92));
  box-shadow:
    0 8rpx 16rpx rgba(129, 98, 64, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    inset 0 -2rpx 0 rgba(214, 193, 171, 0.26);
}

.tea-form-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(247, 239, 228, 0.7));
  border: 1px solid rgba(255, 255, 255, 0.78);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    0 14rpx 24rpx rgba(129, 98, 64, 0.08);
}

.tea-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tea-form__row {
  display: flex;
  gap: 18rpx;
}

.tea-form__row--double {
  align-items: stretch;
}

.tea-form__group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tea-field {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.tea-field--stack {
  margin-top: 20rpx;
}

.tea-field__label {
  flex: none;
  min-width: 84rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tea-input-shell {
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.86);
  box-shadow:
    0 10rpx 18rpx rgba(129, 98, 64, 0.06),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.96),
    inset 0 -2rpx 0 rgba(220, 205, 186, 0.22);
  box-sizing: border-box;
}

.tea-input-shell--wide {
  flex: 1;
}

.tea-input {
  flex: 1;
  height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tea-input__suffix {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.tea-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 28rpx;
}

.tea-action {
  padding: 4rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.tea-action--ghost {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(242, 235, 225, 0.92));
  border: 1px solid rgba(210, 196, 177, 0.56);
  box-shadow:
    0 16rpx 24rpx rgba(129, 98, 64, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.92);
}

.tea-action--primary {
  background: linear-gradient(180deg, #d7a16c 0%, #c6884b 100%);
  box-shadow: 0 16rpx 24rpx rgba(129, 98, 64, 0.1);
}

.tea-action__face {
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.tea-action__face--ghost {
  color: var(--text-primary);
  background: linear-gradient(180deg, #fffdfa 0%, #f3ede5 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    inset 0 -2rpx 0 rgba(205, 190, 171, 0.28);
}

.tea-action__face--primary {
  color: #fffaf2;
  background: linear-gradient(180deg, #cf965f 0%, #c48547 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -2rpx 0 rgba(146, 91, 41, 0.22);
}

.floating-settlement {
  position: fixed;
  right: 30rpx;
  bottom: 170rpx;
  z-index: 30;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  padding: 4rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #d7a16c 0%, #c6884b 100%);
  box-shadow: 0 18rpx 30rpx rgba(185, 122, 68, 0.18);
}

.floating-settlement__inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf2;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #cf965f 0%, #c48547 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -2rpx 0 rgba(146, 91, 41, 0.22);
}
