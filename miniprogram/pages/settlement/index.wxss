.settlement-page {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.settlement-card,
.panel-card {
  padding: 28rpx;
}

.plan-list {
  display: grid;
  gap: 16rpx;
}

.plan-item__title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.plan-item__amount {
  font-size: 34rpx;
  font-weight: 700;
}

.tea-item {
  margin-top: 16rpx;
}

.settlement-copy {
  line-height: 1.7;
}
