.home-root {
  min-height: 100vh;
}

.home-page {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 22rpx;
}

.hero {
  padding: 34rpx 32rpx 32rpx;
}

.action-shell {
  width: 100%;
  padding: 4rpx;
  border-radius: 999rpx;
  box-shadow: 0 16rpx 24rpx rgba(129, 98, 64, 0.1);
  box-sizing: border-box;
}

.action-shell--primary {
  background: linear-gradient(180deg, #d7a16c 0%, #c6884b 100%);
}

.action-shell--secondary {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(242, 235, 225, 0.92));
  border: 1px solid rgba(210, 196, 177, 0.56);
  box-shadow:
    0 16rpx 24rpx rgba(129, 98, 64, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.92);
}

.action-face {
  min-height: 88rpx;
  width: 100%;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.action-face--primary {
  color: #fffaf2;
  background: linear-gradient(180deg, #cf965f 0%, #c48547 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -2rpx 0 rgba(146, 91, 41, 0.22);
}

.action-face--secondary {
  color: var(--text-primary);
  background: linear-gradient(180deg, #fffdfa 0%, #f3ede5 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.94),
    inset 0 -2rpx 0 rgba(205, 190, 171, 0.28);
}

.hero__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 30rpx;
  align-items: stretch;
}

.hero-stat {
  text-align: center;
}

.hero-stat__value {
  font-size: 50rpx;
  font-weight: 600;
  color: var(--brand);
}

.hero-stat__label {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.section-title {
  margin-top: 24rpx;
  margin-bottom: 18rpx;
}

.login-overlay {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.login-overlay__mask {
  position: absolute;
  inset: 0;
  background: rgba(246, 239, 229, 0.78);
  backdrop-filter: blur(14rpx);
}

.login-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 34rpx 36rpx;
  box-sizing: border-box;
}

.login-panel__eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #9a7049;
  font-size: 22rpx;
}

.login-panel__title {
  margin-top: 22rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
}

.login-panel__desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.login-panel__hint {
  margin-top: 20rpx;
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1px solid rgba(255, 255, 255, 0.66);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.login-panel__button {
  margin-top: 30rpx;
}
