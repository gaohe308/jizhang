.profile-page {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-hero,
.panel-card {
  padding: 28rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-head__text {
  flex: 1;
}

.profile-title {
  margin-top: 0;
  font-size: 46rpx;
}

.profile-stats {
  margin-top: 26rpx;
}

.profile-history-item,
.empty-state {
  margin-top: 16rpx;
}

.empty-state {
  padding: 48rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.55);
  color: var(--text-secondary);
  text-align: center;
}
