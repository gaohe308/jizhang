PORT=3000
NODE_ENV=development

# CloudBase basic config
CLOUDBASE_ENV_ID=your-cloudbase-env-id

# WeChat mini program auth
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Service auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CloudBase MySQL
DATABASE_URL=mysql://username:password@host:3306/poker_bookkeeping

# Optional Redis for phase 2
# MVP v1 can leave these empty and run without Redis.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
